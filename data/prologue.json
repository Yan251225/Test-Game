[
    { "type": "scene", "bg": "cherry-blossom", "name": "序章 · 樱花纷飞的邂逅", "clearCharacters": true },

    { "type": "narration", "text": "春风拂过脸颊，带来淡淡的花香。粉白色的花瓣在空中旋转、飘落，像是为我铺就一条梦幻的道路。" },
    { "type": "narration", "text": "今天是我转入「星辰学院」的第一天。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好紧张啊……新学校，新环境，不知道能不能交到朋友呢。）" },

    { "type": "scene", "bg": "school-gate", "name": "星辰学院 · 正门" },

    { "type": "narration", "text": "星辰学院比我想象中更加宏伟。古朴的校门上方，金色的校名在阳光下闪闪发光。校园里绿树成荫，远处传来隐约的欢声笑语。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好大的校园……我得先去教务处办手续才行。嗯，地图上说教务处在……）" },

    { "type": "narration", "text": "我正低头看着手机里的校园地图，完全没注意到前方——" },
    { "type": "narration", "text": "「砰！」" },
    { "type": "narration", "text": "我一头撞上了一个人，手机差点飞出去。" },

    { "type": "character", "charId": "luchen", "position": "center" },
    { "type": "dialogue", "speaker": "luchen", "text": "小心——！" },
    { "type": "narration", "text": "一只手稳稳地扶住了我的手臂，另一只手接住了我即将落地的手机。" },
    { "type": "narration", "text": "我抬起头，看到一张温和的面孔。他穿着整齐的学生会制服，胸前别着「学生会长」的徽章。" },

    { "type": "dialogue", "speaker": "luchen", "text": "你没事吧？走路要小心看路哦。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好……好帅……不对不对，先道歉！）" },

    { "type": "choice", "choices": [
        { "text": "「对不起！我、我在看地图，没注意到……」", "affection": { "luchen": 5 } },
        { "text": "「啊谢谢你！你反应好快啊！」", "affection": { "luchen": 8 } },
        { "text": "「……（太紧张了说不出话）」", "affection": { "luchen": 3 } }
    ]},

    { "type": "dialogue", "speaker": "luchen", "text": "没关系。你是新来的转学生吧？我叫陆辰逸，是学生会长。" },
    { "type": "dialogue", "speaker": "luchen", "text": "你是要去教务处吗？那正好，我带你过去吧。" },

    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（学生会长……好温柔的人。第一天就遇到这么好的学长，感觉这个学校还不错嘛！）" },

    { "type": "scene", "bg": "hallway", "name": "教学楼 · 走廊", "clearCharacters": true },

    { "type": "narration", "text": "陆辰逸领着我穿过教学楼的走廊。路过的学生们都会停下来和他打招呼，他总是微笑着一一回应。" },
    { "type": "narration", "text": "经过一间教室时，我无意间瞥了一眼窗户——" },

    { "type": "character", "charId": "guyan", "position": "center" },
    { "type": "narration", "text": "空荡荡的教室里，靠窗的最后一排座位上，坐着一个少年。" },
    { "type": "narration", "text": "他安静地看着书，阳光透过窗户在他身上洒下斑驳的光影。仿佛整个世界都与他无关。" },

    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（那个人……好安静的感觉。像是画里走出来的一样。）" },

    { "type": "narration", "text": "仿佛感受到了我的目光，他缓缓抬起头。" },
    { "type": "narration", "text": "那双深邃的紫色眼睛与我对视了一瞬——然后，他又低下头，继续看书。" },

    { "type": "dialogue", "speaker": "luchen", "text": "那是顾晏时，和你同班的。他平时不太和人说话，不过……是个好人。" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "playground", "name": "操场", "clearCharacters": true },

    { "type": "narration", "text": "办完手续从教务处出来，路过操场时——" },
    { "type": "narration", "text": "「接住——！！」" },
    { "type": "narration", "text": "一颗篮球突然朝我飞来！" },

    { "type": "character", "charId": "linxiao", "position": "center" },
    { "type": "narration", "text": "紧接着，一道橘色的身影飞速冲过来，稳稳接住了球。" },

    { "type": "dialogue", "speaker": "linxiao", "text": "哇，好险！同学你没事吧？对不起对不起，是我们打球不小心！" },
    { "type": "narration", "text": "阳光下，一个高大的男生单手抱着篮球，露出灿烂的笑容。他的额头还冒着汗珠，校服袖子卷到手肘。" },

    { "type": "choice", "choices": [
        { "text": "「没事！好厉害，你跑得好快！」", "affection": { "linxiao": 8 } },
        { "text": "「吓死我了……不过还好你接住了。」", "affection": { "linxiao": 5 } },
        { "text": "「你们打球要注意安全啊。」", "affection": { "linxiao": 2 } }
    ]},

    { "type": "dialogue", "speaker": "linxiao", "text": "哈哈！对了，我叫林笑寒，体育部的。你是？" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "苏念念。我是今天刚转学过来的。" },
    { "type": "dialogue", "speaker": "linxiao", "text": "转学生！那你一定还不熟悉这里吧。有什么不懂的尽管问我！这个学校我哪里都熟，嘿嘿。" },
    { "type": "dialogue", "speaker": "linxiao", "text": "对了对了，中午食堂的糖醋排骨超级好吃，一定要试试！" },

    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好有活力的男生啊……和他说话感觉心情都变好了。）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "classroom", "name": "高二三班 · 教室", "clearCharacters": true },

    { "type": "narration", "text": "来到教室门口，我深吸一口气推开了门。" },
    { "type": "narration", "text": "全班同学的目光齐刷刷地看向我。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（淡定淡定……）" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "大家好，我叫苏念念，从今天开始转入这个班级，请多多关照！" },

    { "type": "narration", "text": "掌声响起，同学们投来友善的目光。" },
    { "type": "narration", "text": "老师指了指教室后方——" },

    { "type": "character", "charId": "guyan", "position": "center" },
    { "type": "narration", "text": "我的座位，就在顾晏时的旁边。" },
    { "type": "narration", "text": "他依旧在看书，似乎对我的到来毫不关心。" },

    { "type": "choice", "choices": [
        { "text": "（主动打招呼）「你好，我是苏念念，以后请多关照！」", "affection": { "guyan": 5 } },
        { "text": "（安静地坐下，先不打扰他）", "affection": { "guyan": 8 } },
        { "text": "（好奇地偷看他在读什么书）", "affection": { "guyan": 6 } }
    ]},

    { "type": "narration", "text": "不管怎样，他只是微微点了下头，就又沉浸在自己的世界里了。" },
    { "type": "hide_character", "position": "center" },

    { "type": "narration", "text": "窗外，花瓣随风飘入教室。" },
    { "type": "narration", "text": "我望着这个新教室，心中涌起一种奇妙的预感——" },
    { "type": "narration", "text": "在星辰学院的日子，一定不会平凡。" },

    { "type": "narration", "text": "—— 序章 · 完 ——" },

    { "type": "jump", "scriptId": "chapter1" }
]
