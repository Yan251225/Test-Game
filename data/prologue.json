[
    { "type": "scene", "bg": "cherry-blossom", "name": "序章 · 樱花纷飞的邂逅", "clearCharacters": true },

    { "type": "narration", "text": "春风拂过脸颊，带来淡淡的花香。粉白色的花瓣在空中旋转、飘落，像是为我铺就一条梦幻的道路。" },
    { "type": "narration", "text": "今天是我转入「星辰学院」的第一天。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好紧张啊……新学校，新环境，不知道能不能交到朋友呢。）" },

    { "type": "scene", "bg": "school-gate", "name": "星辰学院 · 正门" },
    { "type": "narration", "text": "星辰学院比我想象中更加宏伟。古朴的校门上方，金色的校名在阳光下闪闪发光。" },
    { "type": "narration", "text": "我正低头看着手机里的校园地图，完全没注意到前方——" },
    { "type": "narration", "text": "「砰！」" },

    { "type": "character", "charId": "luchen", "position": "center" },
    { "type": "dialogue", "speaker": "luchen", "text": "小心——！" },
    { "type": "narration", "text": "一只手稳稳地扶住了我的手臂，另一只手接住了我即将落地的手机。他穿着学生会制服，胸前别着「学生会长」的徽章。" },
    { "type": "dialogue", "speaker": "luchen", "text": "你没事吧？你是新来的转学生吧？我叫陆辰逸，是学生会长。我带你去教务处吧。" },

    { "type": "choice", "choices": [
        { "text": "「对不起！谢谢你！」（认真鞠躬）", "affection": { "luchen": 5 } },
        { "text": "「你反应好快啊！好厉害！」（真诚赞叹）", "affection": { "luchen": 8 } },
        { "text": "「……（太紧张了）」", "affection": { "luchen": 3 } }
    ]},
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（学生会长……年级第一的学霸，好温柔的人。）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "library", "name": "教学楼 · 走廊", "clearCharacters": true },
    { "type": "narration", "text": "陆辰逸领着我穿过走廊。经过一间空教室时，我无意间瞥了一眼——" },

    { "type": "character", "charId": "guyan", "position": "center" },
    { "type": "narration", "text": "靠窗最后一排，一个少年安静地看着书。阳光在他身上洒下斑驳光影，仿佛整个世界都与他无关。" },
    { "type": "narration", "text": "他缓缓抬头，那双深邃的紫色眼睛与我对视了一瞬——然后又低下头。" },
    { "type": "dialogue", "speaker": "luchen", "text": "那是顾晏时，和你同班。是个天才，不过不太爱说话。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好安静的感觉……像是画里走出来的一样。）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "playground", "name": "操场", "clearCharacters": true },
    { "type": "narration", "text": "路过操场时——「接住——！！」一颗篮球朝我飞来！" },

    { "type": "character", "charId": "linxiao", "position": "center" },
    { "type": "narration", "text": "一道橘色的身影飞速冲来，稳稳接住了球。" },
    { "type": "dialogue", "speaker": "linxiao", "text": "好险！同学你没事吧？对不起！我叫林笑寒，体育部的！" },

    { "type": "choice", "choices": [
        { "text": "「没事！你跑得好快！」", "affection": { "linxiao": 8 } },
        { "text": "「还好你接住了，谢谢。」", "affection": { "linxiao": 5 } },
        { "text": "「打球小心点……」", "affection": { "linxiao": 2 } }
    ]},
    { "type": "dialogue", "speaker": "linxiao", "text": "转学生！有什么不懂的尽管问我！对了，食堂糖醋排骨超好吃！" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好有活力的男生……和他说话心情都变好了。）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "music-room", "name": "教学楼 · 音乐教室旁", "clearCharacters": true },
    { "type": "narration", "text": "走过走廊时，一阵吉他声从音乐教室传来。旋律慵懒而好听。" },

    { "type": "character", "charId": "xinghe", "position": "center" },
    { "type": "narration", "text": "门半开着，一个少年靠在窗边弹吉他。他注意到我的目光，嘴角微扬。" },
    { "type": "dialogue", "speaker": "xinghe", "text": "偷看别人弹琴可不礼貌哦——不过，能被你这样的美女偷看，是我的荣幸。" },
    { "type": "narration", "text": "他从口袋里变出一朵小花，递到我面前。" },
    { "type": "dialogue", "speaker": "xinghe", "text": "沈星河，星辰学院的星河。记住我的名字哦。" },

    { "type": "choice", "choices": [
        { "text": "「你、你好……」（接过花，脸红了）", "affection": { "xinghe": 8 } },
        { "text": "「你这么对每个女生吗？」（假装淡定）", "affection": { "xinghe": 5 } },
        { "text": "「……我先走了。」（逃走）", "affection": { "xinghe": 3 } }
    ]},
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（这个人……好会撩人！全校公认的校草吗？）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "school-gate", "name": "星辰学院 · 正门广场", "clearCharacters": true },
    { "type": "narration", "text": "这时，校门口突然一阵骚动。一辆黑色的劳斯莱斯缓缓停下，一个少年从车上走出。" },

    { "type": "character", "charId": "xuanmo", "position": "center" },
    { "type": "narration", "text": "他穿着定制的暗红色西装校服，金色袖扣在阳光下闪烁。每一步都带着与生俱来的贵气。" },
    { "type": "narration", "text": "周围的同学纷纷让开一条路，低声议论着。" },
    { "type": "narration", "text": "「那是慕容集团的少爷！」「听说他一个人就包下了学校新图书馆的建设……」" },
    { "type": "narration", "text": "我不小心挡在了他前进的路上——" },
    { "type": "dialogue", "speaker": "xuanmo", "text": "让开。" },
    { "type": "narration", "text": "他冷冷地扫了我一眼，然后——微微停顿了一下。" },
    { "type": "dialogue", "speaker": "xuanmo", "text": "……你是新转来的？走路不要发呆。" },

    { "type": "choice", "choices": [
        { "text": "「对不起！」（赶紧让路）", "affection": { "xuanmo": 3 } },
        { "text": "「啊，你也是这里的学生吗？」（没被吓到）", "affection": { "xuanmo": 8 } },
        { "text": "「你说话好冷淡啊……」（小声嘟囔）", "affection": { "xuanmo": 5 } }
    ]},
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（好有气势的人……那双红色的眼睛好凌厉。不过他刚才……是不是多看了我一眼？）" },
    { "type": "hide_character", "position": "center" },

    { "type": "scene", "bg": "classroom", "name": "高二三班 · 教室", "clearCharacters": true },
    { "type": "narration", "text": "来到教室，我做完自我介绍坐到座位上。座位旁是安静看书的顾晏时。" },
    { "type": "narration", "text": "这时，教室门突然被推开——" },

    { "type": "character", "charId": "edwin", "position": "center" },
    { "type": "narration", "text": "一个金发碧眼的少年走了进来。他穿着深蓝色的校服，却像穿着礼服一样优雅。" },
    { "type": "narration", "text": "全班再次安静下来。老师笑着说：「这位也是今天的转校生。来，自我介绍一下。」" },
    { "type": "dialogue", "speaker": "edwin", "text": "大家好，我是艾德温·霍华德，从英国伦敦来的。很高兴认识大家。" },
    { "type": "narration", "text": "他的中文带着微微的口音，却格外好听。说完后，他微微鞠了一躬——" },
    { "type": "dialogue", "speaker": "edwin", "text": "Please take care of me. ——啊，抱歉，习惯了。请多关照。" },
    { "type": "narration", "text": "女生们发出一阵惊呼。他环顾教室，目光落在我旁边的空位上。" },
    { "type": "dialogue", "speaker": "edwin", "text": "请问，这个座位有人吗？" },
    { "type": "narration", "text": "他对我温和地笑了笑，然后优雅地坐了下来。" },

    { "type": "choice", "choices": [
        { "text": "「欢迎你！我也是今天刚来的转学生！」", "affection": { "edwin": 8 } },
        { "text": "「你好……你的中文说得好好。」", "affection": { "edwin": 5 } },
        { "text": "（偷偷观察他……好像真的贵族一样。）", "affection": { "edwin": 3 } }
    ]},
    { "type": "dialogue", "speaker": "edwin", "text": "Oh? 你也是转校生？那我们是同伴了。一起加油吧。" },
    { "type": "narration", "asThought": true, "speakerName": "苏念念", "text": "（英国来的贵族……好温柔，眼睛像宝石一样蓝。）" },
    { "type": "hide_character", "position": "center" },

    { "type": "narration", "text": "窗外，花瓣随风飘入教室。" },
    { "type": "narration", "text": "学霸学生会长、阴郁天才少年、阳光运动明星、浪漫校草、傲娇富豪之子、英国贵族转校生……" },
    { "type": "narration", "text": "六段缘分，在这个春天悄然展开。" },
    { "type": "narration", "text": "我的星辰学院生活……一定不会平凡。" },
    { "type": "narration", "text": "—— 序章 · 完 ——" }
]
